[Unit]
Description=HermesBridge Next.js frontend test instance
After=network.target hermesbridge.service

[Service]
Type=simple
User=hermes
WorkingDirectory=/opt/hermesbridge-next/runtime
Environment=NODE_ENV=production
Environment=PORT=3001
Environment=HOSTNAME=0.0.0.0
Environment=BACKEND_ORIGIN=http://127.0.0.1:8080
ExecStart=/opt/node-v20.18.3-linux-x64/bin/node /opt/hermesbridge-next/runtime/server.js
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target

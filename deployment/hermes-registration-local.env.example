# Local backend env for HermesBridge registration flow.
# Safe template only. Do not put real secrets into git.

SPRING_PROFILES_ACTIVE=dev
SERVER_ADDRESS=0.0.0.0
SERVER_PORT=8082

APP_DEFAULT_TENANT_KEY=main
APP_API_TOKEN_TTL_DAYS=365
APP_AUTH_ACCESS_TOKEN_TTL_MINUTES=15
APP_AUTH_REFRESH_TOKEN_TTL_DAYS=30
APP_AUTH_REFRESH_COOKIE_NAME=tgclone_refresh_token
APP_CONVERSATIONS_INVITE_TTL_HOURS=168

# For a real local run prefer PostgreSQL, because TDLight/account binding/session flows
# are exercised against persistent storage.
APP_DATASOURCE_URL=jdbc:postgresql://127.0.0.1:5432/hermesbridge
APP_DATASOURCE_USERNAME=hermesbridge
APP_DATASOURCE_PASSWORD=change_me

APP_MEDIA_STORAGE_ROOT=./data/media
APP_MEDIA_MAX_FILE_SIZE_BYTES=20971520
APP_MULTIPART_MAX_FILE_SIZE=20MB
APP_MULTIPART_MAX_REQUEST_SIZE=40MB
APP_MEDIA_STORAGE_PROVIDER=local

TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=123456:replace_me
TELEGRAM_BOT_USERNAME=HermesBridgeBot
TELEGRAM_POLL_TIMEOUT_SECONDS=25

# TDLight local template.
APP_TDLIGHT_ENABLED=true
APP_TDLIGHT_MIGRATION_ENABLED=true
APP_TDLIGHT_ENTITLEMENT_REQUIRED=false
APP_TDLIGHT_PUBLIC_CHANNEL_CLIENT_MODE=REAL
APP_TDLIGHT_BACKFILL_HISTORY_ENABLED=true
APP_TDLIGHT_PUBLIC_CHANNEL_MESSAGE_IMPORT_LIMIT=500
APP_TDLIGHT_IMPORTED_POST_RETENTION_DAYS=7
APP_TDLIGHT_MEDIA_IMPORT_ENABLED=true
APP_TDLIGHT_MAX_IMPORTED_MEDIA_BYTES=20971520
APP_TDLIGHT_MAX_IMPORTED_VIDEO_DURATION_SECONDS=180
APP_TDLIGHT_DEV_ENDPOINTS_ENABLED=true

# Fill these with real values locally if you want TDLight REAL mode.
APP_TDLIGHT_SESSION_ENCRYPTION_KEY=replace_me
APP_TDLIGHT_LIBRARY_PATH=
APP_TDLIGHT_NATIVE_WORKDIR=./data/tdlight/native
APP_TDLIGHT_DATABASE_DIRECTORY=./data/tdlight/db
APP_TDLIGHT_FILES_DIRECTORY=./data/tdlight/files
APP_TDLIGHT_API_ID=
APP_TDLIGHT_API_HASH=
APP_TDLIGHT_SYSTEM_LANGUAGE_CODE=ru
APP_TDLIGHT_DEVICE_MODEL=Hermes Local Dev
APP_TDLIGHT_APPLICATION_VERSION=local-dev
